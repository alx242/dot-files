    (setq eglot-extend-to-xref nil)

    ;; Disable W0026 diagnostics for all Erlang files (unexported function)
    (setq-default eglot-workspace-configuration
                  '(:elp (:diagnostics (:disabled ["W0026"]))))

    ;; Reject workspace file watching requests
    (cl-defmethod eglot-register-capability
        :around (server (method (eql workspace/didChangeWatchedFiles)) _id &rest _params)
        ;; No file watching
        (message "Rejecting file watching registration from %s" (eglot--project-nickname server))
        nil)

    ;; Enable ELP
    (add-to-list 'eglot-server-programs
                 '(erlang-mode . ("elp" "server"))))

;; Make sure eglot doesn't fail during auto-revert of buffers if they change
;; while eglot is still processing the old buffer content
(with-eval-after-load 'eglot
  (advice-add 'eglot-handle-notification
              :around
              (lambda (orig server method &rest params)
                (if (eq method 'textDocument/publishDiagnostics)
                    (let* ((uri (plist-get params :uri))
                           (path (when uri (eglot-uri-to-path uri)))
                           (buf (when path (find-buffer-visiting path))))
                      (when (or (null path) (buffer-live-p buf))
                        (apply orig server method params)))
                  (apply orig server method params)))))

