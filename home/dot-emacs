(defun my-resize-non-term-windows-to-80 ()
  "Resize non-terminal windows to 80 columns and balance the rest.
Terminal-like windows (ghostel/vterm/gptel) share the remaining
horizontal space evenly."
  (interactive)
  (let ((target-width 80))
    ;; Clear out former preserved size to start fresh
    (dolist (window (window-list))
      (window-preserve-size window t nil))
    ;; Set non-terminal windows to 80 chars and mark size as preserved
    (dolist (window (window-list))
      (with-current-buffer (window-buffer window)
        (unless (or (derived-mode-p 'ghostel-mode 'vterm-mode)
                    (bound-and-true-p gptel-mode))
          (let ((delta (- target-width (window-width window))))
            (unless (zerop delta)
              (ignore-errors (window-resize window delta t))))
          (window-preserve-size window t t))))
    ;; balance-windows respects preserved sizes, so only terminal-like
    ;; (ghostel/vterm/gptel) windows end up sharing the remaining space evenly.
    (balance-windows)))

;; Convert region
(defun dos2unix-region (start end)
  "Convert DOS line endings and non-breaking spaces to Unix format."
  (interactive "r")
  (save-excursion
    (save-restriction
      (narrow-to-region start end)

      ;; DOS line endings
      (goto-char (point-min))
      (while (search-forward "\r\n" nil t)
        (replace-match "\n" nil t))

      ;; Non-breaking spaces
      (goto-char (point-min))
      (while (re-search-forward "\u00A0" nil t) ; NBSP
        (replace-match " " nil t)))))           ; Regular space

