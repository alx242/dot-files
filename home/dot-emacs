;; * * * ccrypt auto-save/close * * *
(defvar my/ccrypt-idle-timeout 300
  "Seconds of inactivity before a .cpt-buffer is autosaved and closed.")

(defun my/ccrypt-autosave-and-kill-buffer ()
  (when (and (buffer-file-name)
             (string-match-p "\\.cpt\\'" (buffer-file-name)))
    (when (buffer-modified-p)
      (save-buffer))
    (kill-buffer (current-buffer))))

(defvar my/ccrypt-timer nil
  "Idle timer used to autosave/close .cpt buffers.")

;; Cancel any previous timer (e.g. when reloading this file) before
;; starting a new one, to avoid stacking multiple timers.
(when my/ccrypt-timer
  (cancel-timer my/ccrypt-timer)
  (setq my/ccrypt-timer nil))

(setq my/ccrypt-timer
      (run-with-idle-timer my/ccrypt-idle-timeout t
                           (lambda ()
                             (dolist (buf (buffer-list))
                               (with-current-buffer buf
                                 (my/ccrypt-autosave-and-kill-buffer))))))

